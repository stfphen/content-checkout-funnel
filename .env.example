# Local development placeholders only. Do not reuse these values in production.
POSTGRES_DB=content_funnel_local
POSTGRES_USER=content_funnel_local
POSTGRES_PASSWORD=local-dev-postgres-password-change-me
DATABASE_URL=postgres://content_funnel_local:local-dev-postgres-password-change-me@localhost:5432/content_funnel_local

OWNER_EMAIL=owner@example.com
OWNER_NAME=Local Owner
TEAM_NAME=Local Team
TEAM_SLUG=local-team
# OWNER_PASSWORD is intentionally omitted. Pass it as a one-time environment
# variable when running npm run create-owner.

PUBLIC_APP_URL=http://localhost:8088

RESEND_API_KEY=
GOOGLE_PLACES_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# Signs per-recipient unsubscribe links in outreach emails (HMAC-SHA256).
# Generate one with: openssl rand -base64 32. When unset, no unsubscribe links
# are embedded and all unsubscribe tokens are rejected (fail closed).
UNSUBSCRIBE_SIGNING_SECRET=

# Optional: YouTube Data API v3 key — used only to resolve @handle / user/
# channel links in the hero-video picker. Without it, resolution falls back to
# fetching the public channel page (works, but the API path is the stable one).
YOUTUBE_API_KEY=

# Enterprise Prospecting (account-based) sourcing.
# SEC EDGAR needs NO key (free), but requires a descriptive User-Agent with contact
# info or SEC returns 403. Override the default here.
SEC_EDGAR_USER_AGENT=
# OpenCorporates works anonymously at a limited rate; a token raises limits + unlocks fields.
OPENCORPORATES_API_TOKEN=
# Real per-account research (committee/signals) uses the AI backend below
# (CLAUDE_CODE_OAUTH_TOKEN or ANTHROPIC_API_KEY). Without it, research falls back to an
# offline dossier. Apollo + Hunter (above) supply real contacts when an account has a domain.

# Optional: enables the LLM sales brief in the enrichment workflow.
# When unset, the workflow falls back to the deterministic brief.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Claude (Anthropic) auth for the AI features ---------------------------
# These power the AI Tenant Builder, AI Deep Research, and "Fill missing info".
# Pick ONE path:
#
# (A) Subscription (Claude Max/Pro) via the Claude Agent SDK — no per-token API
#     billing. Generate a long-lived token once with `claude setup-token`
#     (install the CLI: npm i -g @anthropic-ai/claude-code) and paste it here.
#     Preferred when set. Requires the Node runtime (spawns the Claude Code CLI).
CLAUDE_CODE_OAUTH_TOKEN=
#
# (B) Pay-as-you-go API key from console.anthropic.com. Used as an automatic
#     fallback when CLAUDE_CODE_OAUTH_TOKEN is unset (or a subscription call
#     fails). When neither is set, the features return a clear "not configured"
#     error.
ANTHROPIC_API_KEY=

# Optional: override the Deep Research model (defaults to claude-opus-4-8).
LEAD_RESEARCH_MODEL=
# Optional: cap web_search/web_fetch uses per research run for cost control (default 8).
LEAD_RESEARCH_MAX_WEB_SEARCHES=

# Stripe Checkout. When unset, checkout packages fall back to Payment Links or
# lead capture. Use sk_test_/whsec_ locally (whsec_ from `stripe listen`) and
# sk_live_/whsec_ (from the dashboard webhook endpoint) in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Telephony (Twilio) ----------------------------------------------------
# When TWILIO_* are unset, telephony reports "not configured" and the app is
# unaffected. Secrets here only — never store them in tenant config. See
# TELEPHONY.md for the full setup + local-webhook walkthrough.

# Provider selection (only "twilio" is implemented).
TELEPHONY_PROVIDER=twilio

# Public origin Twilio calls for webhooks. MUST match the URL Twilio is
# configured with byte-for-byte (scheme, host, path, no trailing slash) or
# signature verification fails. In dev this is your ngrok https URL; in prod
# your domain. Falls back to NEXT_PUBLIC_APP_URL when unset.
NEXT_PUBLIC_APP_URL=http://localhost:8088
TELEPHONY_WEBHOOK_BASE_URL=

# Twilio credentials (secrets — never commit). Signature verification uses
# TWILIO_AUTH_TOKEN. API key/secret are reserved for future client-token flows.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_WEBHOOK_SECRET=

# Defaults (this pass normalizes +1 US/Canada numbers only).
DEFAULT_COUNTRY_CODE=CA
DEFAULT_TIMEZONE=America/Toronto
