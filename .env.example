# Local development placeholders only. Do not reuse these values in production.
POSTGRES_DB=content_funnel_local
POSTGRES_USER=content_funnel_local
POSTGRES_PASSWORD=local-dev-postgres-password-change-me
DATABASE_URL=postgres://content_funnel_local:local-dev-postgres-password-change-me@localhost:5432/content_funnel_local

OWNER_EMAIL=owner@example.com
OWNER_NAME=Local Owner
TEAM_NAME=Local Team
TEAM_SLUG=local-team
# OWNER_PASSWORD is intentionally omitted. Pass it as a one-time environment
# variable when running npm run create-owner.

PUBLIC_APP_URL=http://localhost:8088

RESEND_API_KEY=
GOOGLE_PLACES_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# Optional: enables the LLM sales brief in the enrichment workflow.
# When unset, the workflow falls back to the deterministic brief.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stripe Checkout. When unset, checkout packages fall back to Payment Links or
# lead capture. Use sk_test_/whsec_ locally (whsec_ from `stripe listen`) and
# sk_live_/whsec_ (from the dashboard webhook endpoint) in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
